# ===========================================
# Arcline App Template - .gitignore
# ===========================================
# .env files are ignored for security. Use .env.example as a reference.
# ===========================================

# Dependencies
node_modules/
venv/
.venv/
env/
ENV/

# Build outputs
dist/
build/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Python packaging
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE and editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Uploads (keep folder structure)
uploads/*
!uploads/.gitkeep
backend/uploads/*
!backend/uploads/.gitkeep

# Environment files
.env
.env.local
.env.*.local

# Confidential pricing data (loaded at runtime, not committed)
backend/data/*.xlsx
backend/data/pmm_workbook.xlsx
